# Application
APP_NAME=Secure-SLM
DEBUG=false
API_PREFIX=/api/v1

# Database (SQLite default; use PostgreSQL in production)
# Stored at data/secure_slm.db (absolute path resolved automatically)
DATABASE_URL=sqlite:///./secure_slm.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/secure_slm

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENCRYPTION_KEY=  # 32-byte base64 Fernet key; auto-generated if empty

# SLM
SLM_MODE=template
# template | huggingface
SLM_MODEL_NAME=microsoft/Phi-3-mini-4k-instruct
SLM_MAX_TOKENS=512
SLM_DEVICE=cpu

# Threat detection
THREAT_CONFIDENCE_THRESHOLD=0.6
ENABLE_ML_CLASSIFIER=true
ENABLE_MITRE_RAG=true

# Default admin (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
